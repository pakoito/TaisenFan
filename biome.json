{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": { "clientKind": "git", "enabled": true, "useIgnoreFile": true },
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on",
				"useSortedAttributes": "on",
				"useSortedProperties": "on"
			}
		},
		"enabled": true
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"javascript": {
		"formatter": {
			"arrowParentheses": "asNeeded",
			"bracketSpacing": false,
			"jsxQuoteStyle": "single",
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"domains": {
			"project": "all",
			"react": "all",
			"test": "all"
		},
		"enabled": true,
		"rules": {
			"a11y": "error",
			"complexity": "error",
			"correctness": "error",
			"nursery": "off",
			"performance": "error",
			"recommended": true,
			"security": "error",
			"style": "error",
			"suspicious": "error"
		}
	},
	"overrides": [
		{
			"includes": ["**/*"],
			"linter": {
				"rules": {
					"correctness": {
						"useImportExtensions": "off",
						"noUnresolvedImports": "off"
					},
					"suspicious": {
						"noReactSpecificProps": "off",
						"noUnknownAtRules": "off"
					},
					"performance": {
						"noImgElement": "off",
						"noNamespaceImport": "off",
						"useSolidForComponent": "off"
					},
					"style": {
						"noMagicNumbers": "off",
						"useExportsLast": "off",
						"useBlockStatements": "off",
						"useNamingConvention": {
							"level": "error",
							"options": {
								"strictCase": false,
								"requireAscii": true,
								"conventions": [
									{
										"selector": { "kind": "objectLiteralProperty" },
										"formats": ["camelCase", "PascalCase", "CONSTANT_CASE"]
									}
								]
							}
						},
						"useFilenamingConvention": {
							"level": "error",
							"options": {
								"strictCase": false,
								"requireAscii": true,
								"filenameCases": ["camelCase", "kebab-case", "PascalCase"]
							}
						},
						"noJsxLiterals": "off"
					},
					"security": {
						"noSecrets": {
							"level": "error",
							"options": {
								"entropyThreshold": 100
							}
						}
					}
				}
			}
		},
		{
			"includes": [
				"vite.config.ts",
				"playwright.config.ts",
				"scripts/**",
				"src/**/*.test.ts",
				"src/**/*.test.tsx"
			],
			"linter": {
				"rules": {
					"correctness": {
						"noNodejsModules": "off"
					},
					"style": {
						"noDefaultExport": "off"
					}
				}
			}
		},
		{
			"includes": ["src/**/*.d.ts"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off"
					}
				}
			}
		},
		{
			"includes": ["src/**/*.test.tsx"],
			"linter": {
				"rules": {
					"performance": {
						"useTopLevelRegex": "off"
					}
				}
			}
		},
		{
			"includes": [
				"src/utils/patcher.ts",
				"src/utils/nds-parser.ts",
				"src/utils/nfp-unpack.ts",
				"src/utils/kpc-decode.ts",
				"src/utils/image-cache.ts",
				"src/workers/rom-worker.ts",
				"src/workers/bps-patch.ts"
			],
			"linter": {
				"rules": {
					"suspicious": { "noBitwiseOperators": "off" },
					"style": { "useForOf": "off", "noNonNullAssertion": "off" },
					"complexity": {
						"noExcessiveCognitiveComplexity": "off",
						"noExcessiveLinesPerFunction": "off"
					}
				}
			}
		},
		{
			"includes": ["src/contexts/RomContext.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					}
				}
			}
		},
		{
			"includes": ["public/**"],
			"formatter": {
				"enabled": false
			},
			"linter": {
				"enabled": false
			}
		}
	]
}
